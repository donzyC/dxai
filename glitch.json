{
  "install": "pip3 install -r requirements.txt",
  "start": "python3 main.py",
  "watch": {
    "ignore": [
      "*.pyc",
      "*.pyo",
      "*.pyd",
      ".git",
      "__pycache__",
      "*.so",
      "*.egg",
      "*.egg-info",
      "dist",
      "build",
      "*.log",
      "*.sqlite3",
      "*.db",
      "*.csv",
      "*.pkl",
      "models/*",
      "datasets/*"
    ]
  },
  "env": {
    "PYTHONUNBUFFERED": "1",
    "PORT": "3000",
    "PYTHON_VERSION": "3.9.0"
  }
} 